    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "inquirer": "^9.3.0",
    "marked": "^14.0.0",
    "marked-terminal": "^7.2.0",
    "node-fetch": "^3.3.2",
    "ora": "^8.1.0",
    "playwright": "^1.58.2"
